source "https://rubygems.org"

ruby ">= 3.1"

gem "sinatra", "~> 4.0"
gem "sinatra-contrib", "~> 4.0"
gem "puma", "~> 6.0"
gem "rackup"
gem "roo", "~> 2.10"   # XLSX/CSV/ODS parsing
gem "csv"               # CSV generation (explicit for Ruby 3.4+)

group :test do
  gem "rspec", "~> 3.13"
  gem "rack-test", "~> 2.1"
  gem "simplecov", "~> 0.22", require: false
end
