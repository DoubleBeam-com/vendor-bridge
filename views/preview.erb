<% rows = @pipeline["rows"] %>
<% columns = @pipeline["columns"] %>
<% stats = @pipeline["stats"] %>
<% filename = @pipeline["filename"] %>
<% id = @pipeline["id"] %>
<% has_posabit = @pipeline["has_posabit"] %>

<div class="max-w-2xl mx-auto space-y-8">

  <!-- Step 1: Flatten results -->
  <div class="text-center">
    <div class="inline-flex items-center justify-center w-16 h-16 bg-green-100 rounded-full mb-4">
      <svg class="w-8 h-8 text-posabit-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
      </svg>
    </div>
    <h1 class="text-2xl font-semibold text-gray-900">Products Extracted</h1>
    <p class="text-gray-600 mt-1">
      Found <strong><%= rows.size %></strong> products across
      <strong><%= stats.size %></strong> categories in <strong><%= filename %></strong>
    </p>
  </div>

  <!-- Stats cards -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
    <% stats.each do |sheet, counts| %>
      <div class="bg-white rounded-lg border border-gray-200 p-4 text-center">
        <div class="text-2xl font-semibold text-posabit-dark"><%= counts["kept"] %></div>
        <div class="text-sm text-gray-500 mt-1"><%= sheet %></div>
      </div>
    <% end %>
  </div>

  <!-- Download flattened CSV -->
  <div class="flex justify-center">
    <a href="/export/<%= id %>"
       class="inline-flex items-center gap-2 px-6 py-2.5 text-sm font-medium text-posabit-green border border-posabit-green rounded-lg hover:bg-green-50 transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
      </svg>
      Download Flattened CSV
    </a>
  </div>

  <!-- Divider -->
  <div class="relative">
    <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-gray-200"></div></div>
    <div class="relative flex justify-center">
      <span class="bg-gray-50 px-4 text-sm text-gray-400">Step 2</span>
    </div>
  </div>

  <% if has_posabit %>
    <!-- POSaBIT catalog loaded -->
    <div class="bg-white rounded-lg border border-gray-200 p-8">
      <div class="text-center mb-6">
        <div class="inline-flex items-center justify-center w-12 h-12 bg-blue-100 rounded-full mb-3">
          <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
        </div>
        <h2 class="text-lg font-semibold text-gray-900">POSaBIT Catalog Loaded</h2>
        <p class="text-gray-600 text-sm mt-1">
          <strong><%= @pipeline["posabit_row_count"] %></strong> products &middot;
          <strong><%= @pipeline["posabit_brands"]&.size %></strong> brands &middot;
          <strong><%= @pipeline["posabit_types"]&.size %></strong> product types
        </p>
        <p class="text-xs text-gray-400 mt-1"><%= @pipeline["posabit_filename"] %></p>
      </div>

      <!-- Download context file -->
      <a href="/context/<%= id %>"
         class="w-full inline-flex items-center justify-center gap-2 px-8 py-3 text-base font-medium text-white bg-posabit-green rounded-lg hover:bg-posabit-green-dark transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
        </svg>
        Download Context File
      </a>

      <div class="mt-6 bg-gray-50 rounded-lg p-4">
        <p class="text-sm font-medium text-gray-700 mb-2">Next steps:</p>
        <ol class="text-sm text-gray-600 space-y-1.5 list-decimal list-inside">
          <li>Open <a href="https://cowork.claude.ai" target="_blank" class="text-posabit-green underline">Claude Cowork</a></li>
          <li>Open the <strong>data_files</strong> folder and attach the <strong>context file</strong></li>
          <li>Ask Claude to review and reconcile the data</li>
          <li>Claude will create <code class="text-xs bg-gray-200 px-1 rounded">reconciliation_output.csv</code> in <code class="text-xs bg-gray-200 px-1 rounded">data_files/</code></li>
          <li>Come back here and click <strong>View Summary</strong> below</li>
          <li><strong>Spot check the output CSV before uploading to POSaBIT</strong></li>
        </ol>
        <p class="text-xs text-gray-400 mt-3">Also works with ChatGPT, Gemini, or any AI assistant.</p>
      </div>
    </div>

    <!-- Divider -->
    <div class="relative">
      <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-gray-200"></div></div>
      <div class="relative flex justify-center">
        <span class="bg-gray-50 px-4 text-sm text-gray-400">Step 3</span>
      </div>
    </div>

    <!-- View Reconciliation Summary -->
    <div class="bg-white rounded-lg border border-gray-200 p-8 text-center">
      <h2 class="text-lg font-semibold text-gray-900 mb-2">Review Reconciliation</h2>
      <p class="text-gray-600 text-sm mb-6">
        After the AI creates <code class="text-xs bg-gray-200 px-1 rounded">reconciliation_output.csv</code>, view a summary of changes by product type.
      </p>
      <a href="/summary/<%= id %>"
         class="w-full inline-flex items-center justify-center gap-2 px-8 py-3 text-base font-medium text-white bg-posabit-green rounded-lg hover:bg-posabit-green-dark transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
        </svg>
        View Summary
      </a>
    </div>

  <% else %>
    <!-- Upload POSaBIT catalog -->
    <div class="bg-white rounded-lg border border-gray-200 p-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-2">Match Against Your POSaBIT Catalog</h2>
      <p class="text-gray-600 text-sm mb-6">
        Upload your current product export from POSaBIT to generate a context file for AI-powered matching.
      </p>

      <form action="/upload-posabit/<%= id %>" method="post" enctype="multipart/form-data" id="posabit-form">
        <div class="mb-4">
          <div id="posabit-drop-zone"
               class="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center cursor-pointer hover:border-posabit-green hover:bg-green-50 transition-colors">
            <svg class="mx-auto h-8 w-8 text-gray-400 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                    d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
            </svg>
            <p class="text-gray-600 text-sm" id="posabit-file-label">Drop your POSaBIT CSV here, or click to browse</p>
            <p class="text-xs text-gray-400 mt-1">CSV file exported from POSaBIT</p>
            <input type="file" name="posabit_file" required id="posabit-file-input" accept=".csv" class="hidden">
          </div>
        </div>

        <button type="submit" id="posabit-submit-btn"
                class="w-full bg-posabit-green text-white rounded-md px-4 py-3 font-medium hover:bg-posabit-green-dark transition-colors disabled:bg-gray-300 disabled:cursor-not-allowed">
          Upload & Generate Context
        </button>
      </form>
    </div>
  <% end %>

  <!-- Start over link -->
  <div class="text-center">
    <a href="/" class="text-sm text-gray-500 hover:text-gray-700">Start over with a new file</a>
  </div>
</div>

<script>
  // POSaBIT file upload drag-and-drop
  const pDropZone = document.getElementById('posabit-drop-zone');
  const pFileInput = document.getElementById('posabit-file-input');
  const pFileLabel = document.getElementById('posabit-file-label');
  const pForm = document.getElementById('posabit-form');
  const pSubmitBtn = document.getElementById('posabit-submit-btn');

  if (pDropZone) {
    pDropZone.addEventListener('click', () => pFileInput.click());
    pDropZone.addEventListener('dragover', (e) => {
      e.preventDefault();
      pDropZone.classList.add('border-posabit-green', 'bg-green-50');
    });
    pDropZone.addEventListener('dragleave', () => {
      pDropZone.classList.remove('border-posabit-green', 'bg-green-50');
    });
    pDropZone.addEventListener('drop', (e) => {
      e.preventDefault();
      pDropZone.classList.remove('border-posabit-green', 'bg-green-50');
      if (e.dataTransfer.files.length) {
        pFileInput.files = e.dataTransfer.files;
        pFileLabel.textContent = e.dataTransfer.files[0].name;
      }
    });
    pFileInput.addEventListener('change', () => {
      if (pFileInput.files.length) pFileLabel.textContent = pFileInput.files[0].name;
    });
    pForm.addEventListener('submit', () => {
      pSubmitBtn.disabled = true;
      pSubmitBtn.textContent = 'Processing...';
    });
  }
</script>
