<% id = @pipeline["id"] %>
<% totals = { "none" => 0, "update" => 0, "insert" => 0 } %>
<% @summary.each_value { |counts| counts.each { |k, v| totals[k] = (totals[k] || 0) + v } } %>
<% grand_total = totals.values.sum %>

<div class="max-w-2xl mx-auto space-y-8">

  <div class="text-center">
    <div class="inline-flex items-center justify-center w-16 h-16 bg-blue-100 rounded-full mb-4">
      <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
      </svg>
    </div>
    <h1 class="text-2xl font-semibold text-gray-900">Reconciliation Summary</h1>
    <p class="text-gray-600 mt-1">
      <strong><%= grand_total %></strong> total products &middot;
      <span class="text-gray-500"><%= totals["none"] %> unchanged</span> &middot;
      <span class="text-yellow-600"><%= totals["update"] %> updated</span> &middot;
      <span class="text-green-600"><%= totals["insert"] %> inserted</span>
    </p>
  </div>

  <% if @metrics %>
  <%
    grade = @metrics["overall_grade"]
    match_rate = @metrics["match_rate"]
    enrichment = @metrics["enrichment_rate"]
    if grade >= 70
      grade_bg = "bg-green-50"
      grade_border = "border-green-200"
      grade_text_lg = "text-green-600"
      grade_bar_bg = "bg-green-500"
      grade_label = "High"
    elsif grade >= 50
      grade_bg = "bg-yellow-50"
      grade_border = "border-yellow-200"
      grade_text_lg = "text-yellow-600"
      grade_bar_bg = "bg-yellow-500"
      grade_label = "Moderate"
    else
      grade_bg = "bg-red-50"
      grade_border = "border-red-200"
      grade_text_lg = "text-red-600"
      grade_bar_bg = "bg-red-500"
      grade_label = "Low"
    end

    # Color helpers for sub-metrics
    mr_color = match_rate >= 70 ? "text-green-600" : (match_rate >= 50 ? "text-yellow-600" : "text-red-600")
    er_color = enrichment >= 70 ? "text-green-600" : (enrichment >= 50 ? "text-yellow-600" : "text-red-600")
  %>
  <div class="<%= grade_bg %> rounded-lg border <%= grade_border %> p-5">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Reconciliation Accuracy</h2>
        <p class="text-xs text-gray-400 mt-0.5"><%= grade_label %> confidence</p>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-3xl font-bold <%= grade_text_lg %>"><%= grade %>%</span>
      </div>
    </div>

    <div class="w-full bg-gray-200 rounded-full h-2.5 mb-4">
      <div class="<%= grade_bar_bg %> h-2.5 rounded-full transition-all" style="width: <%= [grade, 100].min %>%"></div>
    </div>

    <div class="grid grid-cols-2 gap-4 text-sm">
      <div>
        <div class="text-gray-500">Match Rate</div>
        <div class="font-semibold <%= mr_color %>"><%= match_rate %>%</div>
        <div class="text-xs text-gray-400"><%= @metrics["total_updates"] %> of <%= @metrics["total_actionable"] %> vendor products matched</div>
      </div>
      <div>
        <div class="text-gray-500">Data Enrichment</div>
        <div class="font-semibold <%= er_color %>"><%= enrichment %>%</div>
        <div class="text-xs text-gray-400"><%= @metrics["multi_field_updates"] %> of <%= @metrics["total_updates"] %> updates enriched multiple fields</div>
      </div>
    </div>
  </div>
  <% end %>

  <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="bg-gray-50 border-b border-gray-200">
          <th class="text-left px-4 py-3 font-medium text-gray-700">Product Type</th>
          <th class="text-right px-4 py-3 font-medium text-gray-500">No Change</th>
          <th class="text-right px-4 py-3 font-medium text-yellow-600">Updated</th>
          <th class="text-right px-4 py-3 font-medium text-green-600">Inserted</th>
          <th class="text-right px-4 py-3 font-medium text-gray-700">Total</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @summary.sort_by { |type, _| type }.each do |type, counts| %>
          <% row_total = counts.values.sum %>
          <tr>
            <td class="px-4 py-3 font-medium text-gray-900"><%= type %></td>
            <td class="px-4 py-3 text-right text-gray-500"><%= counts["none"] %></td>
            <td class="px-4 py-3 text-right text-yellow-600"><%= counts["update"] > 0 ? counts["update"] : "&mdash;" %></td>
            <td class="px-4 py-3 text-right text-green-600"><%= counts["insert"] > 0 ? counts["insert"] : "&mdash;" %></td>
            <td class="px-4 py-3 text-right font-medium text-gray-900"><%= row_total %></td>
          </tr>
        <% end %>
      </tbody>
      <tfoot>
        <tr class="bg-gray-50 border-t border-gray-200 font-medium">
          <td class="px-4 py-3 text-gray-700">Total</td>
          <td class="px-4 py-3 text-right text-gray-500"><%= totals["none"] %></td>
          <td class="px-4 py-3 text-right text-yellow-600"><%= totals["update"] %></td>
          <td class="px-4 py-3 text-right text-green-600"><%= totals["insert"] %></td>
          <td class="px-4 py-3 text-right text-gray-900"><%= grand_total %></td>
        </tr>
      </tfoot>
    </table>
  </div>

  <% if @updates.any? %>
  <details class="bg-white rounded-lg border border-gray-200 overflow-hidden">
    <summary class="px-4 py-3 cursor-pointer font-medium text-yellow-700 bg-yellow-50 hover:bg-yellow-100 border-b border-gray-200">
      Updated Products (<%= @updates.size %>)
    </summary>
    <table class="w-full text-sm">
      <thead>
        <tr class="bg-gray-50 border-b border-gray-200">
          <th class="text-left px-4 py-2 font-medium text-gray-700">Name</th>
          <th class="text-left px-4 py-2 font-medium text-gray-700">Brand</th>
          <th class="text-left px-4 py-2 font-medium text-gray-700">Type</th>
          <th class="text-left px-4 py-2 font-medium text-gray-700">Fields Changed</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @updates.sort_by { |u| [u[:product_type], u[:brand] || "", u[:name] || ""] }.each do |u| %>
        <tr>
          <td class="px-4 py-2 text-gray-900"><%= u[:name] %></td>
          <td class="px-4 py-2 text-gray-600"><%= u[:brand] %></td>
          <td class="px-4 py-2 text-gray-600"><%= u[:product_type] %></td>
          <td class="px-4 py-2 text-yellow-700 text-xs"><%= u[:updated_fields] %></td>
        </tr>
        <% end %>
      </tbody>
    </table>
  </details>
  <% end %>

  <% if @inserts.any? %>
  <details class="bg-white rounded-lg border border-gray-200 overflow-hidden">
    <summary class="px-4 py-3 cursor-pointer font-medium text-green-700 bg-green-50 hover:bg-green-100 border-b border-gray-200">
      New Products (<%= @inserts.size %>)
    </summary>
    <table class="w-full text-sm">
      <thead>
        <tr class="bg-gray-50 border-b border-gray-200">
          <th class="text-left px-4 py-2 font-medium text-gray-700">Name</th>
          <th class="text-left px-4 py-2 font-medium text-gray-700">Brand</th>
          <th class="text-left px-4 py-2 font-medium text-gray-700">Type</th>
          <th class="text-left px-4 py-2 font-medium text-gray-700">Strain</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @inserts.sort_by { |i| [i[:product_type], i[:brand] || "", i[:name] || ""] }.each do |i| %>
        <tr>
          <td class="px-4 py-2 text-gray-900"><%= i[:name] %></td>
          <td class="px-4 py-2 text-gray-600"><%= i[:brand] %></td>
          <td class="px-4 py-2 text-gray-600"><%= i[:product_type] %></td>
          <td class="px-4 py-2 text-gray-600"><%= i[:strain] %></td>
        </tr>
        <% end %>
      </tbody>
    </table>
  </details>
  <% end %>

  <div class="flex justify-center gap-4">
    <a href="/preview/<%= id %>" class="text-sm text-gray-500 hover:text-gray-700">&larr; Back</a>
    <a href="/" class="text-sm text-gray-500 hover:text-gray-700">Start over</a>
  </div>
</div>
