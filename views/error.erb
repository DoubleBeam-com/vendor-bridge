      <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
      </svg>
    </div>
    <h1 class="text-xl font-semibold text-gray-900 mb-2">Something went wrong</h1>
    <p class="text-gray-600 mb-6"><%= @error_message %></p>
    <a href="/" class="inline-flex items-center gap-2 px-6 py-2.5 text-sm font-medium text-white bg-posabit-green rounded-lg hover:bg-posabit-green-dark transition-colors">
      Try again
