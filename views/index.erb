<div class="max-w-xl mx-auto">
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-8">
    <h1 class="text-2xl font-semibold text-gray-900 mb-2">Upload Product File</h1>
    <p class="text-gray-600 mb-6">Upload a vendor product export to flatten and prepare for PosabiT import.</p>

    <form action="/upload" method="post" enctype="multipart/form-data" id="upload-form">
      <div class="mb-6">
        <label class="block text-sm font-medium text-gray-700 mb-2">Source System</label>
        <select name="source" required
                class="w-full rounded-md border border-gray-300 px-3 py-2 text-gray-900 focus:border-posabit-teal focus:ring-1 focus:ring-posabit-teal">
          <% @sources.each do |s| %>
            <option value="<%= s %>"><%= s.gsub("_", " ").capitalize %></option>
          <% end %>
        </select>
      </div>

      <div class="mb-6">
        <label class="block text-sm font-medium text-gray-700 mb-2">Product File</label>
        <div id="drop-zone"
             class="border-2 border-dashed border-gray-300 rounded-lg p-8 text-center cursor-pointer hover:border-posabit-green hover:bg-green-50 transition-colors">
          <svg class="mx-auto h-10 w-10 text-gray-400 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
          </svg>
          <p class="text-gray-600 mb-1" id="file-label">Drag & drop your file here, or click to browse</p>
          <p class="text-xs text-gray-400">XLSX, CSV, or JSON</p>
          <input type="file" name="file" required id="file-input"
                 accept=".xlsx,.csv,.json"
                 class="hidden">
        </div>
      </div>

      <button type="submit" id="submit-btn"
              class="w-full bg-posabit-green text-white rounded-md px-4 py-3 font-medium hover:bg-posabit-green-dark transition-colors disabled:bg-gray-300 disabled:cursor-not-allowed">
        Flatten & Preview
      </button>
    </form>
  </div>
</div>

<script>
  const dropZone = document.getElementById('drop-zone');
  const fileInput = document.getElementById('file-input');
  const fileLabel = document.getElementById('file-label');
  const form = document.getElementById('upload-form');
  const submitBtn = document.getElementById('submit-btn');

  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('border-posabit-green', 'bg-green-50');
  });
  dropZone.addEventListener('dragleave', () => {
    dropZone.classList.remove('border-posabit-green', 'bg-green-50');
  });
  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-posabit-green', 'bg-green-50');
    if (e.dataTransfer.files.length) {
      fileInput.files = e.dataTransfer.files;
      fileLabel.textContent = e.dataTransfer.files[0].name;
    }
  });
  fileInput.addEventListener('change', () => {
    if (fileInput.files.length) {
      fileLabel.textContent = fileInput.files[0].name;
    }
  });
  form.addEventListener('submit', () => {
    submitBtn.disabled = true;
    submitBtn.textContent = 'Processing...';
  });
</script>
