<% rows = @pipeline["rows"] %>
<% columns = @pipeline["columns"] %>
<% stats = @pipeline["stats"] %>
<% filename = @pipeline["filename"] %>
<% id = @pipeline["id"] %>

<div class="mb-6 flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-semibold text-gray-900">Preview</h1>
    <p class="text-gray-600 mt-1">
      Flattened <strong><%= filename %></strong> &mdash;
      <strong><%= rows.size %></strong> products across
      <strong><%= stats.size %></strong> categories
    </p>
  </div>
  <div class="flex gap-3">
    <a href="/" class="px-4 py-2 text-sm text-gray-600 border border-gray-300 rounded-md hover:bg-gray-50">
      Start Over
    </a>
    <a href="/export/<%= id %>" class="px-4 py-2 text-sm text-white bg-posabit-green rounded-md hover:bg-posabit-green-dark">
      Download CSV
    </a>
  </div>
</div>

<!-- Stats cards -->
<div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
  <% stats.each do |sheet, counts| %>
    <div class="bg-white rounded-lg border border-gray-200 p-4">
      <div class="text-sm text-gray-500"><%= sheet %></div>
      <div class="text-2xl font-semibold text-posabit-dark mt-1"><%= counts["kept"] %></div>
      <div class="text-xs text-gray-400"><%= counts["total"] %> rows scanned</div>
    </div>
  <% end %>
</div>

<!-- Data columns -->
<% data_columns = columns.reject { |c| c.start_with?("_") } %>
<% synthetic_columns = columns.select { |c| c.start_with?("_") } %>

<!-- Data table -->
<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
  <div class="px-4 py-3 border-b border-gray-200 flex items-center justify-between">
    <h2 class="text-sm font-medium text-gray-700">
      Showing first <%= [rows.size, 50].min %> of <%= rows.size %> rows
      &middot; <%= columns.size %> columns
    </h2>
    <div class="flex gap-2">
      <button id="toggle-synthetic" class="text-xs px-2 py-1 rounded border border-gray-300 text-gray-600 hover:bg-gray-50">
        Show metadata columns
      </button>
    </div>
  </div>

  <div class="overflow-x-auto">
    <table class="min-w-full text-sm">
      <thead class="bg-posabit-dark">
        <tr>
          <th class="px-3 py-2 text-left text-xs font-medium text-gray-300 uppercase tracking-wider">#</th>
          <% synthetic_columns.each do |col| %>
            <th class="px-3 py-2 text-left text-xs font-medium text-posabit-teal uppercase tracking-wider synthetic-col hidden whitespace-nowrap"><%= col %></th>
          <% end %>
          <% data_columns.each do |col| %>
            <th class="px-3 py-2 text-left text-xs font-medium text-gray-300 uppercase tracking-wider whitespace-nowrap"><%= col %></th>
          <% end %>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% rows.first(50).each_with_index do |row, i| %>
          <tr class="hover:bg-gray-50">
            <td class="px-3 py-2 text-gray-400 text-xs"><%= i + 1 %></td>
            <% synthetic_columns.each do |col| %>
              <td class="px-3 py-2 text-posabit-teal text-xs synthetic-col hidden whitespace-nowrap"><%= row[col] %></td>
            <% end %>
            <% data_columns.each do |col| %>
              <% val = row[col] %>
              <td class="px-3 py-2 text-gray-700 max-w-xs truncate" title="<%= val %>"><%= val %></td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<script>
  document.getElementById('toggle-synthetic').addEventListener('click', function() {
    const cols = document.querySelectorAll('.synthetic-col');
    const showing = cols[0]?.classList.contains('hidden');
    cols.forEach(c => c.classList.toggle('hidden'));
    this.textContent = showing ? 'Hide metadata columns' : 'Show metadata columns';
  });
</script>
